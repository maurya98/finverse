{
  "name": "finverse-monorepo",
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "build:libs": "turbo run build --filter=@finverse/logger --filter=@finverse/cache --filter=@finverse/utils --filter=@finverse/middlewares",
    "build:backend": "turbo run build --filter='./apps/backend/*'",
    "build:frontend": "turbo run build --filter='./apps/frontend/*'",
    "build:lms": "turbo run build --filter=lms",
    "build:ruleenginebe": "turbo run build --filter=ruleenginebe",
    "build:siteplatform": "turbo run build --filter=@finverse/site-platform",
    "build:admin": "turbo run build --filter=admin_dashboard",
    "build:ruleenginefe": "turbo run build --filter=ruleenginefe",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "clean": "turbo clean && pnpm -r exec rm -rf dist tsconfig.tsbuildinfo",
    "postinstall": "node tooling/scripts/slim-workspace-deps.mjs",
    "slim-deps": "node tooling/scripts/slim-workspace-deps.mjs"
  },
  "engines": {
    "node": ">=22.10.0",
    "pnpm": ">=10.28.2"
  },
  "keywords": [],
  "author": "Saurabh Kumar Maurya",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "axios@<0.30.0": ">=0.30.0",
      "react": "^19.2.0",
      "react-dom": "^19.2.0"
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "turbo": "^2.8.9"
  },
  "dependencies": {}
}