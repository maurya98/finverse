{
    "compilerOptions": {
      "target": "ES2022",
      "moduleResolution": "node",
      "strict": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "isolatedModules": true,
      "baseUrl": ".",
      "paths": {
        "@finverse/utils": ["packages/utils/index.ts"],
        "@finverse/utils/*": ["packages/utils/*"]
      }
    }
  }
  