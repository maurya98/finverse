datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  instanceName = "prisma"
}

enum Role {
  ADMIN
  MAINTAINER
  USER
}

enum Permission {
  READ
  WRITE
  UPDATE
  DELETE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String // Hashed password
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}
