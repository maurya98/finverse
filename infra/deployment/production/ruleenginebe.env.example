# Production environment for Rule Engine Backend
# Database and Redis run on the server (localhost). Use network_mode: host so the container uses server's localhost.
# Copy to .env and fill in values.

NODE_ENV=production
PORT=3000

# Postgres (installed on server - use localhost when using network_mode: host)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ruleengine

# JWT (required for auth)
JWT_SECRET=your-production-jwt-secret
JWT_EXPIRES_IN=7d
