# Production environment for Customer Backend
# Copy to customer.env and fill in values.
# Build from monorepo root. Use --env-file infra/deployment/production/customer.env
#
# With network_mode: host (Linux), use localhost for DATABASE_URL.
# On Mac/Windows Docker Desktop, use host.docker.internal instead of localhost.

NODE_ENV=production
PORT=5000

DATABASE_URL=postgresql://postgres:password@localhost:5432/customer

LOG_PG_URL=
