# Staging environment for Site Platform Backend
# Copy to .env and fill in values.
#
# When running IN DOCKER with DB on the host:
# - Linux + network_mode: host: use localhost (container shares host network).
# - Mac/Windows or without host network: use host.docker.internal so the container
#   can reach Postgres on the host. Example:
#   DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/sp

NODE_ENV=staging
PORT=5001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sp

# Redis (use localhost when using network_mode: host — container shares host network)
# On Mac/Windows or if Redis is on host, use REDIS_HOST=host.docker.internal
REDIS_HOST=localhost
REDIS_PORT=6379
LOG_PG_URL=