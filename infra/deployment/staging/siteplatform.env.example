# Staging environment for Site Platform Backend
# Copy to siteplatform.env and fill in values.
#
# When running IN DOCKER with DB on the host:
#
# • Linux server with network_mode: host (recommended):
#   Use localhost so the container shares the host network and reaches Postgres on 127.0.0.1.
#   Do NOT use 172.17.0.1 — Postgres often only listens on 127.0.0.1, so that can cause
#   "DatabaseNotReachable" (P1001).
#
# • Mac/Windows (Docker Desktop): network_mode: host does not share the host network.
#   Use host.docker.internal so the container can reach Postgres on the host:
#   DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/sp
#   REDIS_HOST=host.docker.internal

NODE_ENV=staging
PORT=5001

# Use localhost when using network_mode: host on Linux. Use host.docker.internal on Mac/Windows.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sp

# Redis (use localhost with network_mode: host on Linux; host.docker.internal on Mac/Windows)
REDIS_HOST=localhost
REDIS_PORT=6379
LOG_PG_URL=
DISABLE_GATEWAY_CREDENTIALS=true
IAM_BASE_URL=