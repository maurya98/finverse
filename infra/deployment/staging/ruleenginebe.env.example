# Staging environment for Rule Engine Backend
# Copy to .env and fill in values. Database and Redis run on the server (localhost).
# For local dev with ruleenginefe, run backend with NODE_ENV=development (e.g. pnpm dev) so CORS allows the frontend origin.

NODE_ENV=staging
PORT=5000

# Comma-separated origins allowed by CORS when NODE_ENV !== development (e.g. your ruleenginefe URL)
# ALLOWED_ORIGINS=http://localhost:5004,https://your-ruleenginefe-domain.com

DATABASE_URL=postgresql://postgres:maurya98@localhost:5432/ruleengine
JWT_SECRET=your-staging-jwt-secret
JWT_EXPIRES_IN=7d

LOG_PG_URL=