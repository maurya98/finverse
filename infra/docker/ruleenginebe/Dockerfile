# Build stage
FROM node:22-slim AS builder

RUN corepack enable && corepack prepare pnpm@10.30.3 --activate

WORKDIR /app

# Copy workspace root
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY turbo.json ./
COPY tooling tooling

# Copy workspace packages used by this app
COPY libs/logger libs/logger
COPY libs/middlewares libs/middlewares
COPY libs/utils libs/utils
COPY apps/backend/ruleenginebe apps/backend/ruleenginebe

# Install all dependencies (no-frozen-lockfile allows build when lockfile is out of sync; run pnpm install at root to update lockfile)
RUN pnpm install --no-frozen-lockfile

# Generate Prisma client
RUN cd apps/backend/ruleenginebe && pnpm exec prisma generate

# Build libs (compile only, skip tests — tooling copied for tsconfig extends)
RUN cd libs/logger && pnpm exec tsc -b
RUN cd libs/utils && pnpm exec rimraf dist && pnpm exec tsc -b --force
RUN cd libs/middlewares && pnpm exec rimraf dist tsconfig.tsbuildinfo && pnpm exec tsc -b

# Build app (run from app dir so only this package's build runs; -r would pass --filter to tsc)
RUN cd apps/backend/ruleenginebe && pnpm run build
RUN cp -r /app/apps/backend/ruleenginebe/src/databases/generated /app/apps/backend/ruleenginebe/dist/databases/

# Production stage
FROM node:22-slim AS runner

RUN corepack enable && corepack prepare pnpm@10.30.3 --activate

WORKDIR /app

# Copy workspace root
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY turbo.json ./
COPY libs/logger libs/logger
COPY libs/middlewares libs/middlewares
COPY libs/utils libs/utils
COPY apps/backend/ruleenginebe apps/backend/ruleenginebe

COPY --from=builder /app/libs/logger/dist libs/logger/dist
COPY --from=builder /app/libs/middlewares/dist libs/middlewares/dist
COPY --from=builder /app/libs/utils/dist libs/utils/dist
COPY --from=builder /app/apps/backend/ruleenginebe/dist apps/backend/ruleenginebe/dist
COPY --from=builder /app/node_modules node_modules
# App node_modules has Prisma runtime deps (@prisma/client-runtime-utils, etc.) — required when running from app dir
COPY --from=builder /app/apps/backend/ruleenginebe/node_modules apps/backend/ruleenginebe/node_modules

# Prisma generated client (already copied inside dist/databases/generated by builder)

ENV NODE_ENV=production
WORKDIR /app/apps/backend/ruleenginebe

EXPOSE 3000

CMD ["node", "dist/app.js"]
